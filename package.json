{
  "name": "couple-finance-tracker",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "corepack pnpm --parallel --filter @app/api --filter @app/web --filter @app/bot dev",
    "build": "corepack pnpm -r --if-present build",
    "lint": "corepack pnpm -r --if-present lint",
    "typecheck": "corepack pnpm -r --if-present typecheck",
    "test": "corepack pnpm -r --if-present test",
    "db:generate": "corepack pnpm --filter @repo/db prisma:generate",
    "db:migrate": "corepack pnpm --filter @repo/db prisma:migrate",
    "db:studio": "corepack pnpm --filter @repo/db prisma:studio"
  },
  "devDependencies": {
    "typescript": "^5.7.3"
  }
}
