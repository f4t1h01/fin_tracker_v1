generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MembershipRole {
  OWNER
  PARTNER
}

enum TransactionKind {
  EXPENSE
  INCOME
}

enum CategoryScope {
  PERSONAL
  SHARED
}

enum GoodsScope {
  PERSONAL
  SHARED
}

enum GoodsConsumptionUnit {
  HOUR
  DAY
  WEEK
  PERMANENT
}

enum GoodsItemEventType {
  INITIAL
  RESTOCK
  CONSUME
  ADJUST_UP
  ADJUST_DOWN
  SET_BALANCE
  AUTO_CONSUMED
  POLICY_UPDATED
  MOVED
  EXPIRY_UPDATED
  ARCHIVED
}

enum GoodsEventSource {
  USER
  SYSTEM
  ADMIN
}

enum GoodsUomGroup {
  COUNT
  MASS
  VOLUME
  OTHER
}

model User {
  id                String        @id @default(cuid())
  telegramId        BigInt        @unique
  lastTelegramChatId BigInt?
  email             String?       @unique
  passwordHash      String?
  passwordSetAt     DateTime?
  coupleCode        String?       @unique
  username          String?
  firstName         String?
  lastName          String?
  birthday          DateTime?
  photoUrl          String?
  telegramPhone     String?
  isAdmin           Boolean       @default(false)
  isDark            Boolean       @default(false)
  weekStartsOn      String        @default("MONDAY") @map("week_starts_on")
  showSharedCategories Boolean    @default(true) @map("show_shared_categories")
  dashboardRateCurrencies String   @default("UZS,USD") @map("dashboard_rate_currencies")
  defaultIncomeCategoryId String? @map("default_income_category_id")
  defaultIncomeCategory Category? @relation("UserDefaultIncomeCategory", fields: [defaultIncomeCategoryId], references: [id], onDelete: SetNull)
  defaultExpenseCategoryId String? @map("default_expense_category_id")
  defaultExpenseCategory Category? @relation("UserDefaultExpenseCategory", fields: [defaultExpenseCategoryId], references: [id], onDelete: SetNull)
  memberships       Membership[]
  coupleBind        CoupleBind?
  transactions      Transaction[]
  createdCategories Category[]
  ownedCategories   Category[]    @relation("OwnedCategories")
  createdCouples    Couple[]      @relation("CreatedCouples")
  createdInvites    Invite[]      @relation("CreatedInvites")
  aiUsageLogs       AiUsageLog[]
  createdGoodsPlaces GoodsPlace[] @relation("GoodsPlaceCreatedBy")
  ownedGoodsPlaces   GoodsPlace[] @relation("GoodsPlaceOwner")
  createdGoodsCategories GoodsCategory[] @relation("GoodsCategoryCreatedBy")
  ownedGoodsCategories   GoodsCategory[] @relation("GoodsCategoryOwner")
  createdGoodsItems  GoodsItem[]  @relation("GoodsItemCreatedBy")
  ownedGoodsItems    GoodsItem[]  @relation("GoodsItemOwner")
  goodsItemEvents    GoodsItemEvent[] @relation("GoodsItemEventCreatedBy")
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
}

model AiModelPricing {
  id                          String      @id @default(cuid())
  provider                    String      @default("OPENAI")
  model                       String
  textInputMicrosPer1m        BigInt?     @map("text_input_micros_per_1m")
  audioInputMicrosPer1m       BigInt?     @map("audio_input_micros_per_1m")
  textOutputMicrosPer1m       BigInt?     @map("text_output_micros_per_1m")
  audioOutputMicrosPer1m      BigInt?     @map("audio_output_micros_per_1m")
  notes                       String?
  effectiveFrom               DateTime    @default(now()) @map("effective_from")
  retiredAt                   DateTime?   @map("retired_at")
  createdByAdminEmail         String?     @map("created_by_admin_email")
  createdAt                   DateTime    @default(now()) @map("created_at")
  aiUsageLogs                 AiUsageLog[]

  @@index([provider, model, effectiveFrom])
  @@index([provider, model, retiredAt])
  @@index([createdAt])
  @@map("ai_model_pricing")
}

model ZeroAdmin {
  email        String   @id
  passwordHash String   @map("password_hash")
  isActive     Boolean  @default(true) @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("0admin")
}

model Couple {
  id           String        @id @default(cuid())
  name         String
  createdById  String
  createdBy    User          @relation("CreatedCouples", fields: [createdById], references: [id], onDelete: Cascade)
  memberships  Membership[]
  coupleBinds  CoupleBind[]
  categories   Category[]
  transactions Transaction[]
  invites      Invite[]
  aiUsageLogs  AiUsageLog[]
  goodsPlaces  GoodsPlace[]
  goodsCategories GoodsCategory[]
  goodsItems   GoodsItem[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model AiUsageLog {
  id                          String   @id @default(cuid())
  provider                    String
  feature                     String
  operation                   String
  status                      String
  model                       String
  endpoint                    String
  correlationId               String   @map("correlation_id")
  providerRequestId           String?  @map("provider_request_id")
  userId                      String?  @map("user_id")
  user                        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  coupleId                    String?  @map("couple_id")
  couple                      Couple?  @relation(fields: [coupleId], references: [id], onDelete: SetNull)
  aiModelPricingId            String?  @map("ai_model_pricing_id")
  aiModelPricing              AiModelPricing? @relation(fields: [aiModelPricingId], references: [id], onDelete: SetNull)
  inputTokens                 Int?     @map("input_tokens")
  outputTokens                Int?     @map("output_tokens")
  totalTokens                 Int?     @map("total_tokens")
  inputTextTokens             Int?     @map("input_text_tokens")
  inputAudioTokens            Int?     @map("input_audio_tokens")
  inputCachedTokens           Int?     @map("input_cached_tokens")
  outputTextTokens            Int?     @map("output_text_tokens")
  outputAudioTokens           Int?     @map("output_audio_tokens")
  textInputPriceMicrosPer1m   BigInt?  @map("text_input_price_micros_per_1m")
  audioInputPriceMicrosPer1m  BigInt?  @map("audio_input_price_micros_per_1m")
  textOutputPriceMicrosPer1m  BigInt?  @map("text_output_price_micros_per_1m")
  audioOutputPriceMicrosPer1m BigInt?  @map("audio_output_price_micros_per_1m")
  inputCostMicros             BigInt?  @map("input_cost_micros")
  outputCostMicros            BigInt?  @map("output_cost_micros")
  totalCostMicros             BigInt?  @map("total_cost_micros")
  errorMessage                String?  @map("error_message")
  createdAt                   DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@index([model])
  @@index([feature])
  @@index([operation])
  @@index([status])
  @@index([correlationId])
  @@index([providerRequestId])
  @@index([userId, createdAt])
  @@index([coupleId, createdAt])
  @@index([aiModelPricingId])
  @@map("ai_usage_log")
}

model AdminAuditLog {
  id              String   @id @default(cuid())
  adminEmail      String?  @map("admin_email")
  actionType      String   @map("action_type")
  targetType      String?  @map("target_type")
  targetId        String?  @map("target_id")
  reason          String?
  requestMetadata Json?    @map("request_metadata")
  beforeState     Json?    @map("before_state")
  afterState      Json?    @map("after_state")
  outcome         String
  errorMessage    String?  @map("error_message")
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@index([adminEmail, createdAt])
  @@index([actionType, createdAt])
  @@index([targetType, targetId])
  @@index([outcome, createdAt])
  @@map("admin_audit_log")
}

model CoupleBind {
  id             String   @id @default(cuid())
  userId         String   @unique @map("user_id")
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  coupleId       String   @map("couple_id")
  couple         Couple   @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  userCoupleCode String   @map("user_couple_code")
  insertedCode   String   @map("inserted_code")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([coupleId])
  @@map("couple_bind")
}

model Membership {
  id        String         @id @default(cuid())
  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  coupleId  String
  couple    Couple         @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  role      MembershipRole
  createdAt DateTime       @default(now())

  @@unique([userId, coupleId])
}

model Category {
  id                       String          @id @default(cuid())
  coupleId                 String
  couple                   Couple          @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  name                     String
  normalizedName           String          @map("normalized_name")
  kind                     TransactionKind
  scope                    CategoryScope   @default(PERSONAL)
  isVisible                Boolean         @default(true) @map("is_visible")
  ownerUserId              String?         @map("owner_user_id")
  ownerUser                User?           @relation("OwnedCategories", fields: [ownerUserId], references: [id], onDelete: SetNull)
  parentCategoryId         String?         @map("parent_category_id")
  parentCategory           Category?       @relation("CategoryHierarchy", fields: [parentCategoryId], references: [id], onDelete: Restrict)
  childCategories          Category[]      @relation("CategoryHierarchy")
  createdById              String?
  createdBy                User?           @relation(fields: [createdById], references: [id], onDelete: SetNull)
  transactions             Transaction[]
  preferredAsDefaultIncomeBy User[]        @relation("UserDefaultIncomeCategory")
  preferredAsDefaultExpenseBy User[]       @relation("UserDefaultExpenseCategory")
  createdAt                DateTime        @default(now())

  @@index([coupleId, kind, scope, ownerUserId, parentCategoryId])
  @@index([coupleId, parentCategoryId])
  @@index([ownerUserId, coupleId, scope])
  @@index([coupleId, kind, normalizedName])
}

model Transaction {
  id         String          @id @default(cuid())
  coupleId   String
  couple     Couple          @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  userId     String
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId String
  category   Category        @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  kind       TransactionKind
  amount     Decimal         @db.Decimal(12, 2)
  currency   String          @default("UZS")
  exchangeRate Decimal       @default(1) @map("exchange_rate") @db.Decimal(18, 6)
  amountInUzs Decimal        @map("amount_in_uzs") @db.Decimal(14, 2)
  note       String?
  happenedAt DateTime
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@index([coupleId, happenedAt])
  @@index([coupleId, currency, happenedAt])
}

model Invite {
  id          String    @id @default(cuid())
  code        String    @unique
  coupleId    String
  couple      Couple    @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  createdById String
  createdBy   User      @relation("CreatedInvites", fields: [createdById], references: [id], onDelete: Cascade)
  expiresAt   DateTime
  consumedAt  DateTime?
  createdAt   DateTime  @default(now())
}

model GoodsPlace {
  id             String      @id @default(cuid())
  coupleId       String      @map("couple_id")
  couple         Couple      @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  scope          GoodsScope
  ownerUserId    String?     @map("owner_user_id")
  ownerUser      User?       @relation("GoodsPlaceOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  name           String
  normalizedName String      @map("normalized_name")
  sortOrder      Int         @default(0) @map("sort_order")
  isVisible      Boolean     @default(true) @map("is_visible")
  isArchived     Boolean     @default(false) @map("is_archived")
  createdById    String?     @map("created_by_id")
  createdBy      User?       @relation("GoodsPlaceCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  items          GoodsItem[]
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  @@index([coupleId, scope, ownerUserId, normalizedName])
  @@index([coupleId, isArchived])
  @@map("goods_place")
}

model GoodsCategory {
  id             String      @id @default(cuid())
  coupleId       String      @map("couple_id")
  couple         Couple      @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  scope          GoodsScope
  ownerUserId    String?     @map("owner_user_id")
  ownerUser      User?       @relation("GoodsCategoryOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  name           String
  normalizedName String      @map("normalized_name")
  sortOrder      Int         @default(0) @map("sort_order")
  isVisible      Boolean     @default(true) @map("is_visible")
  isArchived     Boolean     @default(false) @map("is_archived")
  isSeeded       Boolean     @default(false) @map("is_seeded")
  createdById    String?     @map("created_by_id")
  createdBy      User?       @relation("GoodsCategoryCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  items          GoodsItem[]
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  @@index([coupleId, scope, ownerUserId, normalizedName])
  @@index([coupleId, isArchived])
  @@map("goods_category")
}

model GoodsUom {
  id         String      @id @default(cuid())
  code       String      @unique
  label      String
  groupKey   GoodsUomGroup @default(OTHER) @map("group_key")
  decimals   Int         @default(0)
  isActive   Boolean     @default(true) @map("is_active")
  sortOrder  Int         @default(0) @map("sort_order")
  items      GoodsItem[]
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")

  @@index([isActive, sortOrder])
  @@map("goods_uom")
}

model GoodsItem {
  id                     String               @id @default(cuid())
  coupleId               String               @map("couple_id")
  couple                 Couple               @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  scope                  GoodsScope
  ownerUserId            String?              @map("owner_user_id")
  ownerUser              User?                @relation("GoodsItemOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  placeId                String               @map("place_id")
  place                  GoodsPlace           @relation(fields: [placeId], references: [id], onDelete: Restrict)
  categoryId             String               @map("category_id")
  category               GoodsCategory        @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  uomId                  String               @map("uom_id")
  uom                    GoodsUom             @relation(fields: [uomId], references: [id], onDelete: Restrict)
  name                   String
  normalizedName         String               @map("normalized_name")
  note                   String?
  quantityBase           Decimal              @map("quantity_base") @db.Decimal(14, 3)
  quantityBaseAsOf       DateTime             @map("quantity_base_as_of")
  lowStockThreshold      Decimal              @map("low_stock_threshold") @db.Decimal(14, 3)
  targetQuantity         Decimal              @map("target_quantity") @db.Decimal(14, 3)
  consumptionRateValue   Decimal?             @map("consumption_rate_value") @db.Decimal(14, 3)
  consumptionRateUnit    GoodsConsumptionUnit @default(PERMANENT) @map("consumption_rate_unit")
  consumptionRatePerHour Decimal?             @map("consumption_rate_per_hour") @db.Decimal(18, 8)
  consumptionStartedAt   DateTime?            @map("consumption_started_at")
  expirationDate         DateTime?            @map("expiration_date")
  lastStockEventAt       DateTime             @map("last_stock_event_at")
  lastManualEventAt      DateTime?            @map("last_manual_event_at")
  isArchived             Boolean              @default(false) @map("is_archived")
  createdById            String?              @map("created_by_id")
  createdBy              User?                @relation("GoodsItemCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  events                 GoodsItemEvent[]
  createdAt              DateTime             @default(now()) @map("created_at")
  updatedAt              DateTime             @updatedAt @map("updated_at")

  @@index([coupleId, scope, ownerUserId, isArchived])
  @@index([placeId, categoryId])
  @@index([normalizedName])
  @@index([expirationDate])
  @@index([lastStockEventAt])
  @@map("goods_item")
}

model GoodsItemEvent {
  id            String             @id @default(cuid())
  goodsItemId    String             @map("goods_item_id")
  goodsItem      GoodsItem          @relation(fields: [goodsItemId], references: [id], onDelete: Cascade)
  eventType      GoodsItemEventType @map("event_type")
  quantityDelta  Decimal            @map("quantity_delta") @db.Decimal(14, 3)
  quantityAfter  Decimal            @map("quantity_after") @db.Decimal(14, 3)
  occurredAt     DateTime           @map("occurred_at")
  createdById    String?            @map("created_by_id")
  createdBy      User?              @relation("GoodsItemEventCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  source         GoodsEventSource   @default(USER)
  reason         String?
  metadata       Json?
  createdAt      DateTime           @default(now()) @map("created_at")

  @@index([goodsItemId, occurredAt(sort: Desc)])
  @@index([eventType, occurredAt(sort: Desc)])
  @@map("goods_item_event")
}
