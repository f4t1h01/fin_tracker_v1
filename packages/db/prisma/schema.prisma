generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MembershipRole {
  OWNER
  PARTNER
}

enum TransactionKind {
  EXPENSE
  INCOME
}

model User {
  id                String        @id @default(cuid())
  telegramId        BigInt        @unique
  lastTelegramChatId BigInt?
  email             String?       @unique
  passwordHash      String?
  passwordSetAt     DateTime?
  coupleCode        String?       @unique
  username          String?
  firstName         String?
  lastName          String?
  birthday          DateTime?
  photoUrl          String?
  telegramPhone     String?
  isAdmin           Boolean       @default(false)
  isDark            Boolean       @default(false)
  memberships       Membership[]
  coupleBind        CoupleBind?
  transactions      Transaction[]
  createdCategories Category[]
  createdCouples    Couple[]      @relation("CreatedCouples")
  createdInvites    Invite[]      @relation("CreatedInvites")
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
}

model ZeroAdmin {
  email        String   @id
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("0admin")
}

model Couple {
  id           String        @id @default(cuid())
  name         String
  createdById  String
  createdBy    User          @relation("CreatedCouples", fields: [createdById], references: [id], onDelete: Cascade)
  memberships  Membership[]
  coupleBinds  CoupleBind[]
  categories   Category[]
  transactions Transaction[]
  invites      Invite[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model CoupleBind {
  id             String   @id @default(cuid())
  userId         String   @unique @map("user_id")
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  coupleId       String   @map("couple_id")
  couple         Couple   @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  userCoupleCode String   @map("user_couple_code")
  insertedCode   String   @map("inserted_code")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([coupleId])
  @@map("couple_bind")
}

model Membership {
  id        String         @id @default(cuid())
  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  coupleId  String
  couple    Couple         @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  role      MembershipRole
  createdAt DateTime       @default(now())

  @@unique([userId, coupleId])
}

model Category {
  id          String          @id @default(cuid())
  coupleId    String
  couple      Couple          @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  name        String
  kind        TransactionKind
  createdById String?
  createdBy   User?           @relation(fields: [createdById], references: [id], onDelete: SetNull)
  transactions Transaction[]
  createdAt   DateTime        @default(now())

  @@unique([coupleId, name, kind])
}

model Transaction {
  id         String          @id @default(cuid())
  coupleId   String
  couple     Couple          @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  userId     String
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId String
  category   Category        @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  kind       TransactionKind
  amount     Decimal         @db.Decimal(12, 2)
  currency   String          @default("UZS")
  exchangeRate Decimal       @default(1) @map("exchange_rate") @db.Decimal(18, 6)
  amountInUzs Decimal        @map("amount_in_uzs") @db.Decimal(14, 2)
  note       String?
  happenedAt DateTime
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@index([coupleId, happenedAt])
  @@index([coupleId, currency, happenedAt])
}

model Invite {
  id          String    @id @default(cuid())
  code        String    @unique
  coupleId    String
  couple      Couple    @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  createdById String
  createdBy   User      @relation("CreatedInvites", fields: [createdById], references: [id], onDelete: Cascade)
  expiresAt   DateTime
  consumedAt  DateTime?
  createdAt   DateTime  @default(now())
}
