generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MembershipRole {
  OWNER
  PARTNER
}

enum TransactionKind {
  EXPENSE
  INCOME
}

enum CategoryScope {
  PERSONAL
  SHARED
}

model User {
  id                String        @id @default(cuid())
  telegramId        BigInt        @unique
  lastTelegramChatId BigInt?
  email             String?       @unique
  passwordHash      String?
  passwordSetAt     DateTime?
  coupleCode        String?       @unique
  username          String?
  firstName         String?
  lastName          String?
  birthday          DateTime?
  photoUrl          String?
  telegramPhone     String?
  isAdmin           Boolean       @default(false)
  isDark            Boolean       @default(false)
  weekStartsOn      String        @default("MONDAY") @map("week_starts_on")
  showSharedCategories Boolean    @default(true) @map("show_shared_categories")
  defaultIncomeCategoryId String? @map("default_income_category_id")
  defaultIncomeCategory Category? @relation("UserDefaultIncomeCategory", fields: [defaultIncomeCategoryId], references: [id], onDelete: SetNull)
  defaultExpenseCategoryId String? @map("default_expense_category_id")
  defaultExpenseCategory Category? @relation("UserDefaultExpenseCategory", fields: [defaultExpenseCategoryId], references: [id], onDelete: SetNull)
  memberships       Membership[]
  coupleBind        CoupleBind?
  transactions      Transaction[]
  createdCategories Category[]
  ownedCategories   Category[]    @relation("OwnedCategories")
  createdCouples    Couple[]      @relation("CreatedCouples")
  createdInvites    Invite[]      @relation("CreatedInvites")
  aiUsageLogs       AiUsageLog[]
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
}

model AiModelPricing {
  id                          String      @id @default(cuid())
  provider                    String      @default("OPENAI")
  model                       String
  textInputMicrosPer1m        BigInt?     @map("text_input_micros_per_1m")
  audioInputMicrosPer1m       BigInt?     @map("audio_input_micros_per_1m")
  textOutputMicrosPer1m       BigInt?     @map("text_output_micros_per_1m")
  audioOutputMicrosPer1m      BigInt?     @map("audio_output_micros_per_1m")
  notes                       String?
  effectiveFrom               DateTime    @default(now()) @map("effective_from")
  retiredAt                   DateTime?   @map("retired_at")
  createdByAdminEmail         String?     @map("created_by_admin_email")
  createdAt                   DateTime    @default(now()) @map("created_at")
  aiUsageLogs                 AiUsageLog[]

  @@index([provider, model, effectiveFrom])
  @@index([provider, model, retiredAt])
  @@index([createdAt])
  @@map("ai_model_pricing")
}

model ZeroAdmin {
  email        String   @id
  passwordHash String   @map("password_hash")
  isActive     Boolean  @default(true) @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("0admin")
}

model Couple {
  id           String        @id @default(cuid())
  name         String
  createdById  String
  createdBy    User          @relation("CreatedCouples", fields: [createdById], references: [id], onDelete: Cascade)
  memberships  Membership[]
  coupleBinds  CoupleBind[]
  categories   Category[]
  transactions Transaction[]
  invites      Invite[]
  aiUsageLogs  AiUsageLog[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model AiUsageLog {
  id                          String   @id @default(cuid())
  provider                    String
  feature                     String
  operation                   String
  status                      String
  model                       String
  endpoint                    String
  correlationId               String   @map("correlation_id")
  providerRequestId           String?  @map("provider_request_id")
  userId                      String?  @map("user_id")
  user                        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  coupleId                    String?  @map("couple_id")
  couple                      Couple?  @relation(fields: [coupleId], references: [id], onDelete: SetNull)
  aiModelPricingId            String?  @map("ai_model_pricing_id")
  aiModelPricing              AiModelPricing? @relation(fields: [aiModelPricingId], references: [id], onDelete: SetNull)
  inputTokens                 Int?     @map("input_tokens")
  outputTokens                Int?     @map("output_tokens")
  totalTokens                 Int?     @map("total_tokens")
  inputTextTokens             Int?     @map("input_text_tokens")
  inputAudioTokens            Int?     @map("input_audio_tokens")
  inputCachedTokens           Int?     @map("input_cached_tokens")
  outputTextTokens            Int?     @map("output_text_tokens")
  outputAudioTokens           Int?     @map("output_audio_tokens")
  textInputPriceMicrosPer1m   BigInt?  @map("text_input_price_micros_per_1m")
  audioInputPriceMicrosPer1m  BigInt?  @map("audio_input_price_micros_per_1m")
  textOutputPriceMicrosPer1m  BigInt?  @map("text_output_price_micros_per_1m")
  audioOutputPriceMicrosPer1m BigInt?  @map("audio_output_price_micros_per_1m")
  inputCostMicros             BigInt?  @map("input_cost_micros")
  outputCostMicros            BigInt?  @map("output_cost_micros")
  totalCostMicros             BigInt?  @map("total_cost_micros")
  errorMessage                String?  @map("error_message")
  createdAt                   DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@index([model])
  @@index([feature])
  @@index([operation])
  @@index([status])
  @@index([correlationId])
  @@index([providerRequestId])
  @@index([userId, createdAt])
  @@index([coupleId, createdAt])
  @@index([aiModelPricingId])
  @@map("ai_usage_log")
}

model AdminAuditLog {
  id              String   @id @default(cuid())
  adminEmail      String?  @map("admin_email")
  actionType      String   @map("action_type")
  targetType      String?  @map("target_type")
  targetId        String?  @map("target_id")
  reason          String?
  requestMetadata Json?    @map("request_metadata")
  beforeState     Json?    @map("before_state")
  afterState      Json?    @map("after_state")
  outcome         String
  errorMessage    String?  @map("error_message")
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@index([adminEmail, createdAt])
  @@index([actionType, createdAt])
  @@index([targetType, targetId])
  @@index([outcome, createdAt])
  @@map("admin_audit_log")
}

model CoupleBind {
  id             String   @id @default(cuid())
  userId         String   @unique @map("user_id")
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  coupleId       String   @map("couple_id")
  couple         Couple   @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  userCoupleCode String   @map("user_couple_code")
  insertedCode   String   @map("inserted_code")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([coupleId])
  @@map("couple_bind")
}

model Membership {
  id        String         @id @default(cuid())
  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  coupleId  String
  couple    Couple         @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  role      MembershipRole
  createdAt DateTime       @default(now())

  @@unique([userId, coupleId])
}

model Category {
  id                       String          @id @default(cuid())
  coupleId                 String
  couple                   Couple          @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  name                     String
  normalizedName           String          @map("normalized_name")
  kind                     TransactionKind
  scope                    CategoryScope   @default(PERSONAL)
  isVisible                Boolean         @default(true) @map("is_visible")
  ownerUserId              String?         @map("owner_user_id")
  ownerUser                User?           @relation("OwnedCategories", fields: [ownerUserId], references: [id], onDelete: SetNull)
  parentCategoryId         String?         @map("parent_category_id")
  parentCategory           Category?       @relation("CategoryHierarchy", fields: [parentCategoryId], references: [id], onDelete: Restrict)
  childCategories          Category[]      @relation("CategoryHierarchy")
  createdById              String?
  createdBy                User?           @relation(fields: [createdById], references: [id], onDelete: SetNull)
  transactions             Transaction[]
  preferredAsDefaultIncomeBy User[]        @relation("UserDefaultIncomeCategory")
  preferredAsDefaultExpenseBy User[]       @relation("UserDefaultExpenseCategory")
  createdAt                DateTime        @default(now())

  @@index([coupleId, kind, scope, ownerUserId, parentCategoryId])
  @@index([coupleId, parentCategoryId])
  @@index([ownerUserId, coupleId, scope])
  @@index([coupleId, kind, normalizedName])
}

model Transaction {
  id         String          @id @default(cuid())
  coupleId   String
  couple     Couple          @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  userId     String
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId String
  category   Category        @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  kind       TransactionKind
  amount     Decimal         @db.Decimal(12, 2)
  currency   String          @default("UZS")
  exchangeRate Decimal       @default(1) @map("exchange_rate") @db.Decimal(18, 6)
  amountInUzs Decimal        @map("amount_in_uzs") @db.Decimal(14, 2)
  note       String?
  happenedAt DateTime
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@index([coupleId, happenedAt])
  @@index([coupleId, currency, happenedAt])
}

model Invite {
  id          String    @id @default(cuid())
  code        String    @unique
  coupleId    String
  couple      Couple    @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  createdById String
  createdBy   User      @relation("CreatedInvites", fields: [createdById], references: [id], onDelete: Cascade)
  expiresAt   DateTime
  consumedAt  DateTime?
  createdAt   DateTime  @default(now())
}
